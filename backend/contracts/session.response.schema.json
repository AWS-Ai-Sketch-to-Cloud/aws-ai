{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sketch-to-cloud.local/schema/session-detail-response-v2.json",
  "title": "SessionDetailResponseV2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sessionId",
    "projectId",
    "versionNo",
    "inputType",
    "status",
    "createdAt",
    "updatedAt",
    "contractVersion"
  ],
  "properties": {
    "sessionId": {
      "type": "string",
      "minLength": 1
    },
    "projectId": {
      "type": "string",
      "minLength": 1
    },
    "versionNo": {
      "type": "integer",
      "minimum": 1
    },
    "inputType": {
      "type": "string",
      "enum": ["TEXT", "SKETCH", "TEXT_WITH_SKETCH"]
    },
    "inputText": {
      "type": ["string", "null"]
    },
    "inputImageUrl": {
      "type": ["string", "null"]
    },
    "status": {
      "type": "string",
      "enum": [
        "CREATED",
        "ANALYZING",
        "ANALYZED",
        "GENERATING_TERRAFORM",
        "GENERATED",
        "COST_CALCULATED",
        "FAILED"
      ]
    },
    "architecture": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["schemaVersion", "architectureJson"],
      "properties": {
        "schemaVersion": {
          "type": "string",
          "minLength": 1
        },
        "architectureJson": {
          "$ref": "../A_JSON_스키마_v1.json"
        }
      }
    },
    "terraform": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["validationStatus", "terraformCode"],
      "properties": {
        "validationStatus": {
          "type": "string"
        },
        "terraformCode": {
          "type": "string"
        },
        "validationOutput": {
          "type": ["string", "null"]
        }
      }
    },
    "cost": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["currency", "region", "assumptionJson", "monthlyTotal", "costBreakdownJson"],
      "properties": {
        "currency": {
          "type": "string"
        },
        "region": {
          "type": "string"
        },
        "assumptionJson": {
          "type": "object"
        },
        "monthlyTotal": {
          "type": "number"
        },
        "costBreakdownJson": {
          "type": "object"
        }
      }
    },
    "error": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": ["string", "null"]
        },
        "message": {
          "type": ["string", "null"]
        }
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "contractVersion": {
      "type": "string",
      "const": "v2"
    }
  }
}

