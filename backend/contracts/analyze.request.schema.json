{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sketch-to-cloud.local/schema/analyze-request-v1.json",
  "title": "AnalyzeRequestV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["inputText"],
  "properties": {
    "inputText": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "inputType": {
      "type": "string",
      "enum": ["text", "sketch"],
      "default": "text"
    },
    "inputImageDataUrl": {
      "type": "string",
      "minLength": 1
    }
  }
}

